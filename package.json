{
  "name": "skilltags",
  "version": "2.0.3",
  "description": "Generate category commands that help agents find the right installed skills from one prompt tag. No more hunting for skill names.",
  "bin": {
    "skilltags": "bin/skilltags.js"
  },
  "scripts": {
    "postinstall": "node ./bin/postinstall.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cursor",
    "cursor-ide",
    "skills",
    "agent-skills",
    "skills.sh",
    "skilltags",
    "ai",
    "llm",
    "mcp",
    "claude",
    "codex",
    "copilot"
  ],
  "author": "Steven Light",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steve-piece/skilltags.git"
  },
  "homepage": "https://github.com/steve-piece/skilltags#readme",
  "files": [
    "bin/",
    "lib/",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.2.1"
  }
}
