{
  "name": "skilltags",
  "version": "2.1.3",
  "description": "Generate global or project-scoped Cursor command files that group installed skills by category, so agents can load the right skills from one prompt tag.",
  "bin": {
    "skilltags": "bin/skilltags.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node ./bin/postinstall.js",
    "use:npmReadme": "cp NPM-README.md README.md",
    "use:gitReadme": "git checkout -- README.md",
    "prepublishOnly": "npm run use:npmReadme",
    "postpublish": "npm run use:gitReadme"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cursor",
    "cursor-ide",
    "skills",
    "agent-skills",
    "skills.sh",
    "skilltags",
    "ai",
    "llm",
    "mcp",
    "claude",
    "codex",
    "copilot"
  ],
  "author": "Steven Light",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steve-piece/skilltags.git"
  },
  "homepage": "https://github.com/steve-piece/skilltags#readme",
  "files": [
    "bin/",
    "lib/",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.2.1"
  },
  "devDependencies": {
    "execa": "^9.6.1",
    "vitest": "^4.0.18"
  }
}
